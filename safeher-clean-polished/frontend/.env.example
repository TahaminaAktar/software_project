# Optional. In Expo Go, SafeHer now auto-detects your computer IP from Expo's host URI.
# Use this only if auto-detection fails or if your backend is deployed.
# Example for physical device testing:
# EXPO_PUBLIC_API_URL=http://192.168.0.105:5000/api
# Example for production:
# EXPO_PUBLIC_API_URL=https://api.safeher.com/api
EXPO_PUBLIC_BACKEND_PORT=5000
